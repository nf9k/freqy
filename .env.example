# ── Application ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
APP_URL=https://your-domain.example.com

# ── Database ────────────────────────────────────────────────────
# DB_HOST must match the container_name of the db service
DB_HOST=freqy-db
DB_NAME=freqy
DB_USER=freqy_user
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# ── Email (SMTP2GO) ─────────────────────────────────────────────
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=465
SMTP_USER=your-smtp2go-username
SMTP_PASSWORD=your-smtp2go-password
SMTP_FROM_EMAIL=noreply@your-domain.example.com
SMTP_FROM_NAME=Freqy Coordination System

# ── Admin notifications ─────────────────────────────────────────
# Comma-separated list of email addresses to notify on new applications
ADMIN_NOTIFY_EMAILS=admin@your-domain.example.com
