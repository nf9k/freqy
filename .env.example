# ── Application ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
APP_URL=https://your-domain.example.com

# ── Database ────────────────────────────────────────────────────
# DB_HOST must match the container_name of the db service
DB_HOST=freqy-db
DB_NAME=freqy
DB_USER=freqy_user
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# ── Email (SMTP2GO) ─────────────────────────────────────────────
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=465
SMTP_USER=your-smtp2go-username
SMTP_PASSWORD=your-smtp2go-password
SMTP_FROM_EMAIL=noreply@your-domain.example.com
SMTP_FROM_NAME=Freqy Coordination System

# ── Admin notifications ─────────────────────────────────────────
# Comma-separated list of email addresses to notify on new applications
ADMIN_NOTIFY_EMAILS=admin@your-domain.example.com

# ── NOPC notifications ──────────────────────────────────────────────
# Comma-separated list of adjacent area coordinator emails for NOPC notifications
#NOPC_EMAILS=oarc.cc@gmail.com,mail@miarc.com,wcall@mchsi.com,nopc@ilra.net

# ── DB Export ───────────────────────────────────────────────────────
# Title line included in all export formats. {date} is replaced with today's date.
#EXPORT_TITLE=Frequency Coordination Database Export as of {date}

# ── hCaptcha (human verification on login, register, password reset) ─
# Get keys at https://dashboard.hcaptcha.com/
# Leave blank to disable captcha (e.g. during initial setup or on private installs)
#HCAPTCHA_SITE_KEY=your-site-key
#HCAPTCHA_SECRET_KEY=your-secret-key

# ── Frequency coordination separation rules ──────────────────────
# Co-channel minimum separation in miles (default: 120)
#FREQ_CO_CHANNEL_MILES=120
#
# Adjacent channel rules as JSON: band_key -> [[max_offset_khz, min_sep_miles], ...]
# Entries must be sorted ascending by max_offset_khz within each band.
#FREQ_ADJ_RULES={"50":[[20,20]],"144":[[10,40],[15,30],[20,25],[30,20]],"222":[[20,25],[40,5]],"440":[[25,5],[50,1]],"902":[[25,5],[50,1]],"1296":[[25,5],[50,1]]}

# ── Demo mode ────────────────────────────────────────────────────
# Set DEMO_MODE=true to enable the public demo instance.
# Enables the demo banner, /demo/reset endpoint, and disables SMTP.
# DEMO_RESET_TOKEN is used by cron to trigger resets via HTTP POST.
#DEMO_MODE=false
#DEMO_RESET_TOKEN=change-me-to-a-random-secret
